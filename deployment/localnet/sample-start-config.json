  "gcp": null,
  "node": {
    "my_near_account_id": "node0.test.near",
    "near_responder_account_id": "responder0.test.near",
    "number_of_responder_keys": 5,
    "web_ui": "0.0.0.0:8080",
    "migration_web_ui": "0.0.0.0:8081",
    "pprof_bind_address": "127.0.0.1:34001",
    "indexer": {
      "validate_genesis": false,
      "sync_mode": "Latest",
      "finality": "Final",
      "concurrency": 2,
      "mpc_contract_id": "mpc-contract.test.near",
      "port_override": null
    },
    "triple": {
      "concurrency": 2,
      "desired_triples_to_buffer": 100,
      "timeout_sec": 600,
      "parallel_triple_generation_stagger_time_sec": 5
    },
    "presignature": {
      "concurrency": 2,
      "desired_presignatures_to_buffer": 50,
      "timeout_sec": 300
