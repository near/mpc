    "signature": {
      "timeout_sec": 30
    },
    "ckd": {
      "timeout_sec": 30
    },
    "keygen": {
      "timeout_sec": 60
    },
    "foreign_chains": {
      "ethereum": {
        "timeout_sec": 60,
        "max_retries": 3,
        "providers": {
          "alchemy": {
            "rpc_url": "https://eth-mainnet.g.alchemy.com/v2/{API_KEY}",
            "api_variant": "alchemy",
            "auth": {
              "kind": "path",
              "placeholder": "{API_KEY}",
              "token": { "env": "ALCHEMY_API_KEY" }
            }
          }
        }
      },
      "solana": {
        "timeout_sec": 60,
        "max_retries": 3,
        "providers": {
          "helius": {
            "rpc_url": "https://mainnet.helius-rpc.com",
            "api_variant": "helius",
            "auth": {
              "kind": "header",
              "name": "authorization",
              "scheme": "Bearer",
              "token": { "env": "HELIUS_API_KEY" }
            }
          }
        }
      }
    },
    "cores": null
  }
