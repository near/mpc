# Foreign-chain RPC provider API keys, referenced by
# deployment/localnet/foreign_chains.yaml via `{ env: <VAR_NAME> }` and by
# deployment/localnet/verify_foreign_chains.sh at startup.
#
# Copy this file to `.env` (same directory) and fill in real values:
#   cp deployment/localnet/.env-example deployment/localnet/.env
# Then before running the node or verify script:
#   set -a; source deployment/localnet/.env; set +a
#
# The actual `.env` is gitignored. This file (`.env-example`) is committed.

ANKR_API_KEY=
BLOCKDAEMON_API_KEY=
BLOCKPI_API_KEY=
DRPC_API_KEY=
DWELLIR_API_KEY=
INFURA_API_KEY=
NOWNODES_API_KEY=
TATUM_API_KEY=
