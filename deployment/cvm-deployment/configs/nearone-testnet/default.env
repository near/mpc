# NearOne testnet MPC node — production CVM on Bob
# Based on: deployment/cvm-deployment/default.env

APP_NAME="nearone-testnet-mpc"

# dstack-vmm RPC (systemd service on Bob)
VMM_RPC=http://127.0.0.1:10000

# Production sealing (local SGX key provider, not KMS)
SEALING_KEY_TYPE=SGX

# Local-only agent port (dstack UI / CVM access)
EXTERNAL_DSTACK_AGENT_PORT=127.0.0.1:9208

# SSH port is exposed by the dev OS image. Kept local-only.
EXTERNAL_SSH_PORT=127.0.0.1:9209

# External MPC ports (host machine) — bound to Bob's public IP
EXTERNAL_MPC_PUBLIC_DEBUG_PORT=46.105.87.136:8080
EXTERNAL_MPC_LOCAL_DEBUG_PORT=127.0.0.1:3030
EXTERNAL_MPC_DECENTRALIZED_STATE_SYNC=46.105.87.136:24567
EXTERNAL_MPC_MAIN_PORT=46.105.87.136:80
EXTERNAL_MPC_MIGRATION_PORT=46.105.87.136:8079

# Internal MPC ports (inside CVM)
INTERNAL_MPC_PUBLIC_DEBUG_PORT=8080
INTERNAL_MPC_LOCAL_DEBUG_PORT=3030
INTERNAL_MPC_DECENTRALIZED_STATE_SYNC=24567
INTERNAL_MPC_MAIN_PORT=80
INTERNAL_MPC_MIGRATION_PORT=8079

# dstack OS image — dev variant for the first migration (SSH into CVM available
# for debugging). Both dev and prod measurements are allowed on the contract.
# Switch to dstack-0.5.8 for the permanent production deployment after the
# migration is validated.
OS_IMAGE=dstack-dev-0.5.8

# Templates
DOCKER_COMPOSE_FILE_PATH=launcher_docker_compose.yaml
USER_CONFIG_FILE_PATH=user-config.toml

# Disk for the CVM (VCPU=8 and MEMORY=64G are hardcoded in deploy-launcher.sh because they are measured)
DISK=500G
