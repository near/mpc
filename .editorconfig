root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Insta snapshots may legitimately contain trailing whitespace
[*.{snap,snap.new}]
trim_trailing_whitespace = false

# Markdown uses two trailing spaces for hard line breaks
[*.md]
trim_trailing_whitespace = false

# Generated by `cargo about`; not hand-edited
[third-party-licenses/licenses.html]
trim_trailing_whitespace = false
