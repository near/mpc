              "$ref": "#/definitions/BitcoinTxId"
            }
          }
        },
        "BitcoinTxId": {
          "type": "string",
          "pattern": "^(?:[0-9A-Fa-f]{2})*$"
        },
        "BlockConfirmations": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "Bls12381G1PublicKey": {
          "type": "string"
        },
        "Bls12381G2PublicKey": {
          "type": "string"
        },
        "CKDAppPublicKey": {
          "oneOf": [
            {
              "type": "object",
